<Window x:Class="AiMusicWorkstation.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Music Workstation" Height="800" Width="1150" 
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        MinWidth="900" MinHeight="600"
        Background="#121212">
    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToggleButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                BorderThickness="1"
                                BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="Content" Value="M"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#8B0000"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="IndianRed"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="Content" Value="S"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#7A6000"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="Gold"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </MultiTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" x:Key="VolumeInputBox">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="IBeam"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="0,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2E3D"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#007ACC"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LIBRARY ===== -->
        <Grid Grid.Column="0" Background="#181818">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="15,20,15,10">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="LIBRARY" Foreground="#888" FontWeight="Bold"
                               FontSize="12" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="⟳ Refresh Metadata"
                            Click="RefreshMetadata_Click"
                            Background="#1A2E3D" Foreground="#007ACC"
                            FontSize="10" FontWeight="Bold"
                            Padding="8,4" Cursor="Hand"/>
                </Grid>
                <Border Background="#2A2A2A" CornerRadius="5" Padding="8,5" Margin="0,0,0,10">
                    <TextBox x:Name="SearchBox" TextChanged="SearchBox_TextChanged"
                             Background="Transparent" BorderThickness="0"
                             Foreground="White" CaretBrush="White"
                             VerticalContentAlignment="Center"/>
                </Border>
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="SortCombo" Grid.Column="0"
                              SelectionChanged="Filter_Changed" SelectedIndex="0"
                              Background="#333" Foreground="Black">
                        <ComboBoxItem Content="Latest"/>
                        <ComboBoxItem Content="A-Z"/>
                        <ComboBoxItem Content="BPM"/>
                    </ComboBox>
                    <ComboBox x:Name="GenreCombo" Grid.Column="2"
                              SelectionChanged="Filter_Changed" SelectedIndex="0"
                              Background="#333" Foreground="Black">
                        <ComboBoxItem Content="All Genres"/>
                    </ComboBox>
                </Grid>
            </StackPanel>

            <ListBox x:Name="ProjectList" Grid.Row="1"
                     PreviewMouseRightButtonDown="ProjectList_PreviewRightClick"
                     Background="Transparent" BorderThickness="0"
                     SelectionChanged="ProjectList_SelectionChanged"
                     Margin="10,0,10,10">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3" Background="Transparent" Tag="{Binding}">
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="✏️ Rename" Click="Rename_Click"
                                              Tag="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <MenuItem Header="📁 Move to Group..." Click="MoveToGroup_Click"
                                              Tag="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    <Separator/>
                                    <MenuItem Header="❌ Delete" Click="Delete_Click"
                                              Tag="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#007ACC"
                                    CornerRadius="2" Margin="0,2"/>
                            <StackPanel Grid.Column="1" Margin="10,4,4,4">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold" FontSize="13"
                                           Foreground="White" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Artist}"
                                           FontSize="11" Foreground="#999"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Bpm, StringFormat={}{0:F0}}"
                                               Foreground="#555" FontSize="10"/>
                                    <TextBlock Text=" BPM • " Foreground="#444" FontSize="10"/>
                                    <TextBlock Text="{Binding Key}"
                                               Foreground="#555" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Text=" • " Foreground="#444" FontSize="10"/>
                                    <TextBlock Text="{Binding Genre}"
                                               Foreground="#666" FontSize="10" FontStyle="Italic"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <!-- Grupprubriker med separator-linjer -->
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Grid Margin="0,8,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Height="1" VerticalAlignment="Center"
                                   Fill="#007ACC" Opacity="0.4"/>
                                    <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   Foreground="#007ACC" FontSize="10"
                                   FontWeight="Bold" Opacity="0.8"
                                   Margin="8,0" VerticalAlignment="Center"/>
                                    <Rectangle Grid.Column="2" Height="1" VerticalAlignment="Center"
                                   Fill="#007ACC" Opacity="0.4"/>
                                </Grid>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>
            </ListBox>
        </Grid>

        <!-- ===== HUVUDINNEHÅLL ===== -->
        <Grid Grid.Column="1" Margin="30,20,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="AI MUSIC WORKSTATION" Foreground="White"
                           FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="MASTER VOL" Foreground="Gray" VerticalAlignment="Center"
                               Margin="0,0,10,0" FontSize="10" FontWeight="Bold"/>
                    <Slider Width="100" Minimum="0" Maximum="1" Value="1"
                            IsMoveToPointEnabled="True" Name="SliderMaster" Tag="master"
                            ValueChanged="MasterVolume_Changed"
                            PreviewMouseLeftButtonUp="VolumeSlider_PreviewMouseLeftButtonUp"
                            VerticalAlignment="Center"/>
                    <TextBox x:Name="InputMasterVol" Text="100" Width="35" Margin="8,0,0,0"
                             VerticalAlignment="Center" Style="{StaticResource VolumeInputBox}"
                             Tag="master" KeyDown="VolumeInput_KeyDown" LostFocus="VolumeInput_LostFocus"/>
                    <TextBlock Text="%" Foreground="#555" VerticalAlignment="Center"
                               Margin="2,0,0,0" FontSize="10"/>
                </StackPanel>
            </Grid>

            <!-- VIEWBOX -->
            <Viewbox Grid.Row="1" Stretch="Uniform">
                <StackPanel Width="900" Margin="0,10,0,10">

                    <!-- IMPORT-SEKTION (döljs efter laddning) -->
                    <Border x:Name="ImportSection" Margin="0,0,0,15">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="YoutubeLinkBox" Height="45"
                                         Style="{StaticResource VolumeInputBox}"
                                         TextAlignment="Left" Padding="15,0"
                                         VerticalContentAlignment="Center" FontSize="14"
                                         Foreground="#AAA"
                                         GotFocus="YoutubeBox_GotFocus"
                                         LostFocus="YoutubeBox_LostFocus"
                                         Text="Paste YouTube or Spotify Link here..."/>
                                <Button Grid.Column="1" Content="⬇ DOWNLOAD"
                                        Click="YoutubeDownload_Click"
                                        Width="140" Height="45" Margin="10,0,0,0"
                                        Background="#CC0000" Foreground="White"
                                        FontWeight="Bold" Cursor="Hand"/>
                            </Grid>
                            <Button Content="📂 OPEN LOCAL AUDIO FILE"
                                    Click="ImportButton_Click"
                                    Width="280" Height="40" Background="#2A2A2A"
                                    Foreground="White" FontWeight="Bold"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- STATUS + PROGRESS -->
                    <TextBlock x:Name="StatusLabel" Text="Ready"
                               Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <ProgressBar x:Name="AnalysisProgress" IsIndeterminate="True"
                                 Height="3" Width="400" Visibility="Hidden"
                                 Foreground="#007ACC" Background="#222"
                                 BorderThickness="0" Margin="0,0,0,10"/>

                    <!-- ADD SONG-knapp (syns när import är gömd) -->
                    <Button x:Name="ShowImportBtn"
                            Content="＋ Add Song"
                            Visibility="Collapsed"
                            Click="ShowImport_Click"
                            Width="120" Height="32"
                            Background="#1A2E3D" Foreground="#007ACC"
                            FontSize="12" FontWeight="Bold"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,15"
                            Cursor="Hand"/>

                    <!-- TEMPO + KEY -->
                    <UniformGrid Columns="3" Margin="0,10,0,10" Width="750">

                        <!-- BPM -->
                        <StackPanel>
                            <TextBlock Text="TEMPO" Foreground="#555"
                                       HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="BpmText" Text="--" Foreground="#007ACC"
                                           FontSize="56" FontWeight="Bold" Cursor="Hand"
                                           ToolTip="Klicka för att växla BPM"
                                           Background="Transparent"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <Border x:Name="OfficialBadge" Visibility="Collapsed"
                                            Background="#1DB954" CornerRadius="12" Padding="8,3">
                                        <TextBlock Text="✓ SPOTIFY" Foreground="White"
                                                   FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                    <Border x:Name="AiBadge" Visibility="Collapsed"
                                            Background="#333" CornerRadius="12" Padding="8,3">
                                        <TextBlock Text="⚡ AI ANALYSIS" Foreground="#888"
                                                   FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- TIME SIGNATURE -->
                        <StackPanel>
                            <TextBlock Text="TIME SIG" Foreground="#555"
                                       HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="TimeSigText" Text="--" Foreground="#007ACC"
                                           FontSize="56" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <Border Background="#333" CornerRadius="12" Padding="8,3"
                                        HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <TextBlock x:Name="TimeSigBadge" Text="⚡ AI ANALYSIS"
                                               Foreground="#888" FontSize="9" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- KEY -->
                        <StackPanel>
                            <TextBlock Text="KEY" Foreground="#555"
                                       HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="KeyText" Text="--" Foreground="#007ACC"
                                           FontSize="56" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                    <Border x:Name="KeyOfficialBadge" Visibility="Collapsed"
                                            Background="#1DB954" CornerRadius="12" Padding="8,3">
                                        <TextBlock Text="✓ SPOTIFY" Foreground="White"
                                                   FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                    <Border x:Name="KeyAiBadge" Visibility="Collapsed"
                                            Background="#333" CornerRadius="12" Padding="8,3">
                                        <TextBlock Text="⚡ AI ANALYSIS" Foreground="#888"
                                                   FontSize="9" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </UniformGrid>

                    <!-- TRANSPOSE -->
                    <Border Background="#1A1A1A" CornerRadius="10" Padding="15,8"
                            Margin="0,-5,0,15" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="TRANSPOSE" Foreground="#555" FontSize="10"
                                       FontWeight="Bold" VerticalAlignment="Center"
                                       Margin="0,0,15,0"/>
                            <Button x:Name="TransposeDownBtn" Content="−" Width="32" Height="32"
                                    Background="#2A2A2A" Foreground="White" FontSize="18"
                                    Click="TransposeDown_Click" Cursor="Hand"/>
                            <Border Background="#222" CornerRadius="6" Padding="12,4" Margin="6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TransposeLabel" Text="0"
                                               Foreground="#007ACC" FontSize="18" FontWeight="Bold"
                                               MinWidth="20" TextAlignment="Center"/>
                                    <TextBlock Text=" st" Foreground="#555" FontSize="11"
                                               VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                </StackPanel>
                            </Border>
                            <Button x:Name="TransposeUpBtn" Content="+" Width="32" Height="32"
                                    Background="#2A2A2A" Foreground="White" FontSize="18"
                                    Click="TransposeUp_Click" Cursor="Hand"/>
                            <Button Content="↺" Width="32" Height="32" Margin="6,0,0,0"
                                    Background="#2A2A2A" Foreground="#888" FontSize="16"
                                    Click="TransposeReset_Click" Cursor="Hand"
                                    ToolTip="Reset to original key"/>
                            
                            <!-- METRONOM -->
                            <Border Background="#1A1A1A" CornerRadius="6" Padding="8,4" Margin="16,0,0,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border x:Name="MetronomePulse" Width="10" Height="10"
                                            Background="#007ACC" CornerRadius="5"
                                            Opacity="0.2" Margin="0,0,8,0"/>
                                    <ComboBox x:Name="TimeSignatureCombo" Width="55"
                                              Background="#333" Foreground="Black"
                                              FontSize="11" Margin="0,0,8,0"
                                              SelectedIndex="0">
                                    <ComboBoxItem Content="4/4"/>
                                    <ComboBoxItem Content="3/4"/>
                                    <ComboBoxItem Content="6/8"/>
                                    <ComboBoxItem Content="2/4"/>
                                    </ComboBox>
                                    <ToggleButton x:Name="CountInBtn"
                                                  Content="Count In"
                                                  FontSize="10" FontWeight="Bold"
                                                  Padding="6,4" Cursor="Hand"
                                                  Margin="0,0,8,0"
                                                  ToolTip="Inräkning innan låten startar">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Background" Value="#2A2A2A"/>
                                                <Setter Property="Foreground" Value="#888"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Background" Value="#1A3A2A"/>
                                                        <Setter Property="Foreground" Value="#1DB954"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <TextBlock x:Name="MetronomeBeatText" Text=""
                                               Foreground="#007ACC" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               MinWidth="50"/>
                                    <ToggleButton x:Name="MetronomeBtn"
                                                  Content="🥁 Metro"
                                                  Click="MetronomeToggle_Click"
                                                  Background="#2A2A2A" Foreground="White"
                                                  FontSize="11" FontWeight="Bold"
                                                  Padding="8,4" Cursor="Hand"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- LYRICS + CHORD PANEL -->
                    <Border Background="#1E1E1E" CornerRadius="12"
                            Height="220" Margin="0,0,0,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="ChordColumn" Width="190"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition x:Name="SectionsColumn" Width="180"/>
                            </Grid.ColumnDefinitions>

                            <!-- CHORD / SCALE PANEL -->
                            <Border x:Name="ChordPanel" Grid.Column="0" Background="#161616"
                                    CornerRadius="12,0,0,12" Padding="10,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Flik-knappar: Chord | Scale -->
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <ToggleButton x:Name="TabChordBtn" Grid.Column="0"
                                                      Content="Chord" IsChecked="True"
                                                      Click="TabChord_Click">
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton">
                                                    <Setter Property="Background" Value="#252525"/>
                                                    <Setter Property="Foreground" Value="#888"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="FontSize" Value="10"/>
                                                    <Setter Property="Padding" Value="4,3"/>
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="Background" Value="#2A5A7A"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2a2a2a"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ToggleButton.Style>
                                        </ToggleButton>

                                        <ToggleButton x:Name="TabScaleBtn" Grid.Column="1"
                                                      Content="Scale"
                                                      Click="TabScale_Click">
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton">
                                                    <Setter Property="Background" Value="#252525"/>
                                                    <Setter Property="Foreground" Value="#888"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="FontSize" Value="10"/>
                                                    <Setter Property="Padding" Value="4,3"/>
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="Background" Value="#2A5A7A"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2a2a2a"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ToggleButton.Style>
                                        </ToggleButton>
                                    </Grid>

                                    <!-- Chord-vy -->
                                    <StackPanel x:Name="ChordView" Grid.Row="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="CurrentChordText" Text="--"
                                                   Foreground="Gold" FontSize="30" FontWeight="Bold"
                                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <Border x:Name="ChordDiagramHost"
                                                HorizontalAlignment="Center"
                                                Background="Transparent"/>
                                        <TextBlock x:Name="NextChordsText" Text=""
                                                   Foreground="#555" FontSize="9"
                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- Scale-vy -->
                                    <StackPanel x:Name="ScaleView" Grid.Row="1" Visibility="Collapsed">
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton x:Name="PentatonicBtn" Grid.Column="0"
                                                          Content="Penta" IsChecked="True"
                                                          Click="ScaleToggle_Click">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Background" Value="#252525"/>
                                                        <Setter Property="Foreground" Value="#888"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="FontSize" Value="10"/>
                                                        <Setter Property="Padding" Value="3,2"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Background" Value="#2A5A7A"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#2a2a2a"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                            <ToggleButton x:Name="MajorScaleBtn" Grid.Column="1"
                                                          Content="Maj/Min"
                                                          Click="ScaleToggle_Click">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Background" Value="#252525"/>
                                                        <Setter Property="Foreground" Value="#888"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="FontSize" Value="10"/>
                                                        <Setter Property="Padding" Value="3,2"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Background" Value="#2A5A7A"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#2a2a2a"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                        </Grid>
                                        <TextBlock x:Name="ScaleKeyText" Text=""
                                                   Foreground="#aaa" FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,4"/>
                                        <Border x:Name="ScaleDiagramHost"
                                                HorizontalAlignment="Center"
                                                Background="Transparent"
                                                ClipToBounds="True"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- SECTIONS PANEL (standalone, kolumn 2) -->
                            <Border x:Name="SectionsPanel" Grid.Column="2"
                                    Background="#161616" CornerRadius="0,12,12,0"
                                    Margin="1,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <Border Grid.Row="0" Padding="8,6"
                                            BorderThickness="0,0,0,1" BorderBrush="#2A2A2A">
                                        <TextBlock Text="SECTIONS" Foreground="#555"
                                                   FontSize="10" FontWeight="Bold"/>
                                    </Border>

                                    <!-- Sektionslista -->
                                    <ScrollViewer Grid.Row="1"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl x:Name="SectionsList"
                                                      Focusable="False">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border x:Name="SectionItemBorder"
                                                            Background="Transparent"
                                                            Padding="4,5,4,5"
                                                            Cursor="Hand"
                                                            Focusable="False"
                                                            FocusVisualStyle="{x:Null}"
                                                            MouseDown="SectionItem_MouseDown"
                                                            MouseLeftButtonDown="SectionItem_DoubleClick">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#1A2530"/>
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Background" Value="#0D2035"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0"
                                                                    Width="3" CornerRadius="2"
                                                                    Margin="0,0,7,0"
                                                                    Background="{Binding ColorBrush}"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Label}"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="12" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#AAA"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                                <Setter Property="Foreground" Value="White"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding TimeDisplay}"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="10">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#555"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                                <Setter Property="Foreground" Value="#2A5A7A"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                        <Border.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="❌ Remove" Click="RemoveSection_Click"
                                                                          Tag="{Binding}"/>
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Edit toolbar -->
                                    <Border Grid.Row="2" Background="#111" Padding="6,5"
                                            BorderThickness="0,1,0,0" BorderBrush="#2A2A2A">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton x:Name="SectionsEditBtn" Grid.Column="0"
                                                          Content="✏️ Edit" Click="SectionsEdit_Click"
                                                          Background="#2A2A2A" Foreground="#888"
                                                          FontSize="10" Padding="6,3"
                                                          Cursor="Hand" Height="22"/>
                                            <Grid x:Name="SectionsEditBar" Grid.Column="1"
                                                    Visibility="Collapsed" Margin="6,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox x:Name="SectionTypeCombo" Grid.Column="0"
                                                          Background="#222" Foreground="White"
                                                          FontSize="10" BorderThickness="0"
                                                          SelectedIndex="0" Height="22">
                                                    <ComboBox.ItemContainerStyle>
                                                        <Style TargetType="ComboBoxItem">
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="Background" Value="#222"/>
                                                        </Style>
                                                    </ComboBox.ItemContainerStyle>
                                                    <ComboBoxItem Content="Intro"/>
                                                    <ComboBoxItem Content="Verse"/>
                                                    <ComboBoxItem Content="Pre"/>
                                                    <ComboBoxItem Content="Chorus"/>
                                                    <ComboBoxItem Content="Bridge"/>
                                                    <ComboBoxItem Content="Solo"/>
                                                    <ComboBoxItem Content="Instrumental"/>
                                                    <ComboBoxItem Content="Outro"/>
                                                    <ComboBoxItem Content="Break"/>
                                                </ComboBox>
                                                <Button Grid.Column="1" Content="＋ Mark"
                                                        Click="AddSection_Click"
                                                        Background="#2A5A7A" Foreground="White"
                                                        FontSize="10" FontWeight="Bold"
                                                        Padding="8,3" Margin="4,0,0,0"
                                                        Cursor="Hand" Height="22"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>


                            <!-- LYRICS -->
                            <Grid x:Name="LyricsPanel" Grid.Column="1"
                                  Margin="16,10,16,10" ClipToBounds="True">
                                <ScrollViewer x:Name="LyricsScroller"
                                              VerticalScrollBarVisibility="Hidden"
                                              HorizontalScrollBarVisibility="Disabled"
                                              CanContentScroll="False">
                                    <ListBox x:Name="LyricsList"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                             SelectionChanged="LyricsLine_Click"
                                             VerticalAlignment="Top">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0,1"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="Bd" Background="Transparent">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#1A2E3D"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}"
                                                           FontWeight="Bold"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                            <Setter Property="FontSize" Value="13"/>
                                                            <Setter Property="Margin" Value="0,2"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                    <Setter Property="FontSize" Value="17"/>
                                                                    <Setter Property="Margin" Value="0,3"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Grid>

                            <!-- Toggle-knappar uppe till höger -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,6,8,0">
                                <ToggleButton x:Name="ToggleChordsBtn"
                                              Content="🎸" ToolTip="Visa/dölj ackord"
                                              Width="26" Height="26" FontSize="13"
                                              IsChecked="True"
                                              Click="ToggleChords_Click"
                                              Background="#2A2A2A" Foreground="White"/>
                                <ToggleButton x:Name="ToggleLyricsBtn"
                                              Content="🎤" ToolTip="Visa/dölj lyrics"
                                              Width="26" Height="26" FontSize="13"
                                              IsChecked="True" Margin="4,0,0,0"
                                              Click="ToggleLyrics_Click"
                                              Background="#2A2A2A" Foreground="White"/>
                                <ToggleButton x:Name="ToggleSectionsBtn"
                                              Content="🎼" ToolTip="Visa/dölj sections"
                                              Width="26" Height="26" FontSize="13"
                                              IsChecked="True" Margin="4,0,0,0"
                                              Click="ToggleSections_Click"
                                              Background="#2A2A2A" Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </Border>




                    <!-- MIXER -->
                    <UniformGrid Columns="4" Width="750" HorizontalAlignment="Center">

                        <!-- DRUMS -->
                        <StackPanel Margin="15">
                            <TextBlock Text="DRUMS" Foreground="#888"
                                       HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBox x:Name="InputDrums" Text="80" Width="35"
                                         Style="{StaticResource VolumeInputBox}" Tag="drums"
                                         KeyDown="VolumeInput_KeyDown" LostFocus="VolumeInput_LostFocus"/>
                                <TextBlock Text="%" Foreground="#555" VerticalAlignment="Center"
                                           FontSize="11" Margin="2,0,0,0"/>
                            </StackPanel>
                            <Slider Orientation="Vertical" Height="180" Minimum="0" Maximum="1"
                                    Value="0.8" IsMoveToPointEnabled="True" Name="VolDrums"
                                    ValueChanged="Volume_Changed"
                                    PreviewMouseLeftButtonUp="VolumeSlider_PreviewMouseLeftButtonUp"
                                    Tag="drums" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                <ToggleButton Content="M" Width="35" Height="30" Margin="3"
                                              Foreground="IndianRed" Tag="drums" Click="Mute_Click"/>
                                <ToggleButton Content="S" Width="35" Height="30" Margin="3"
                                              Foreground="Gold" Tag="drums" Click="Solo_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- BASS -->
                        <StackPanel Margin="15">
                            <TextBlock Text="BASS" Foreground="#888"
                                       HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBox x:Name="InputBass" Text="80" Width="35"
                                         Style="{StaticResource VolumeInputBox}" Tag="bass"
                                         KeyDown="VolumeInput_KeyDown" LostFocus="VolumeInput_LostFocus"/>
                                <TextBlock Text="%" Foreground="#555" VerticalAlignment="Center"
                                           FontSize="11" Margin="2,0,0,0"/>
                            </StackPanel>
                            <Slider Orientation="Vertical" Height="180" Minimum="0" Maximum="1"
                                    Value="0.8" IsMoveToPointEnabled="True" Name="VolBass"
                                    ValueChanged="Volume_Changed"
                                    PreviewMouseLeftButtonUp="VolumeSlider_PreviewMouseLeftButtonUp"
                                    Tag="bass" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                <ToggleButton Content="M" Width="35" Height="30" Margin="3"
                                              Foreground="IndianRed" Tag="bass" Click="Mute_Click"/>
                                <ToggleButton Content="S" Width="35" Height="30" Margin="3"
                                              Foreground="Gold" Tag="bass" Click="Solo_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- OTHER -->
                        <StackPanel Margin="15">
                            <TextBlock Text="OTHER" Foreground="#888"
                                       HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBox x:Name="InputOther" Text="80" Width="35"
                                         Style="{StaticResource VolumeInputBox}" Tag="other"
                                         KeyDown="VolumeInput_KeyDown" LostFocus="VolumeInput_LostFocus"/>
                                <TextBlock Text="%" Foreground="#555" VerticalAlignment="Center"
                                           FontSize="11" Margin="2,0,0,0"/>
                            </StackPanel>
                            <Slider Orientation="Vertical" Height="180" Minimum="0" Maximum="1"
                                    Value="0.8" IsMoveToPointEnabled="True" Name="VolOther"
                                    ValueChanged="Volume_Changed"
                                    PreviewMouseLeftButtonUp="VolumeSlider_PreviewMouseLeftButtonUp"
                                    Tag="other" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                <ToggleButton Content="M" Width="35" Height="30" Margin="3"
                                              Foreground="IndianRed" Tag="other" Click="Mute_Click"/>
                                <ToggleButton Content="S" Width="35" Height="30" Margin="3"
                                              Foreground="Gold" Tag="other" Click="Solo_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- VOCALS -->
                        <StackPanel Margin="15">
                            <TextBlock Text="VOCALS" Foreground="#888"
                                       HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBox x:Name="InputVocals" Text="80" Width="35"
                                         Style="{StaticResource VolumeInputBox}" Tag="vocals"
                                         KeyDown="VolumeInput_KeyDown" LostFocus="VolumeInput_LostFocus"/>
                                <TextBlock Text="%" Foreground="#555" VerticalAlignment="Center"
                                           FontSize="11" Margin="2,0,0,0"/>
                            </StackPanel>
                            <Slider Orientation="Vertical" Height="180" Minimum="0" Maximum="1"
                                    Value="0.8" IsMoveToPointEnabled="True" Name="VolVocals"
                                    ValueChanged="Volume_Changed"
                                    PreviewMouseLeftButtonUp="VolumeSlider_PreviewMouseLeftButtonUp"
                                    Tag="vocals" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                <ToggleButton Content="M" Width="35" Height="30" Margin="3"
                                              Foreground="IndianRed" Tag="vocals" Click="Mute_Click"/>
                                <ToggleButton Content="S" Width="35" Height="30" Margin="3"
                                              Foreground="Gold" Tag="vocals" Click="Solo_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Viewbox>

            <!-- TRANSPORT -->
            <StackPanel Grid.Row="2" Margin="0,8,0,0">
                <Grid Width="750" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="38"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="38"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="CurrentTimeText" Grid.Column="0"
                               Text="00:00" Foreground="#888"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>

                    <Button Grid.Column="1" Content="«" Width="32" Height="26"
                            Background="#222" Foreground="#888" FontSize="14"
                            Click="SeekBack_Click" Cursor="Hand" ToolTip="Back 10 seconds"/>

                    <Slider Grid.Column="2" x:Name="TimelineSlider"
                            Minimum="0" Maximum="100"
                            IsMoveToPointEnabled="True"
                            Thumb.DragStarted="Timeline_DragStarted"
                            Thumb.DragCompleted="Timeline_DragCompleted"
                            ValueChanged="Timeline_ValueChanged"
                            VerticalAlignment="Center"/>

                    <Button Grid.Column="3" Content="»" Width="32" Height="26"
                            Background="#222" Foreground="#888" FontSize="14"
                            Click="SeekForward_Click" Cursor="Hand" ToolTip="Forward 10 seconds"/>

                    <TextBlock x:Name="TotalTimeText" Grid.Column="4"
                               Text="00:00" Foreground="#888"
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                    <ToggleButton x:Name="LoopBtn" Content="🔁" Width="50" Height="50"
                                  Background="#222" Foreground="SkyBlue" FontSize="20"
                                  Click="Loop_Click"/>
                    <Button x:Name="PlayPauseBtn" Content="▶" Width="75" Height="75"
                            Margin="20,0" Background="#1DB954" Foreground="White"
                            FontSize="35" Click="PlayPause_Click"/>
                    <Button Content="⏹" Width="50" Height="50"
                            Background="#222" Foreground="IndianRed"
                            FontSize="20" Click="Stop_Click"/>
                    <Button x:Name="ExportBtn" Content="💾 EXPORT MIX"
                            Click="ExportMix_Click" Width="140" Height="50"
                            Margin="30,0,0,0" Background="#007ACC"
                            Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
