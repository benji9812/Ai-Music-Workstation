<Window x:Class="AiMusicWorkstation.Desktop.InputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" 
        Width="450" 
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Border Background="#252525" BorderBrush="#444" BorderThickness="1" CornerRadius="8" Padding="20">
        <StackPanel>
            <TextBlock x:Name="PromptText" Text="Enter Name:" Foreground="#DDD" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

            <TextBox x:Name="InputBox" 
                     Background="#333" 
                     Foreground="White" 
                     BorderThickness="1" 
                     BorderBrush="#555"
                     Padding="8"
                     FontSize="13"
                     CaretBrush="White"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" IsCancel="True" Width="80" Height="30" Margin="0,0,10,0" 
                        Background="#444" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Save" IsDefault="True" Click="Ok_Click" Width="80" Height="30" 
                        Background="#007ACC" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>