<Window x:Class="AiMusicWorkstation.Desktop.EditSectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Section" Height="220" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    <StackPanel Margin="20,20,20,8">

        <TextBlock Text="Name" Foreground="#888"
                   FontSize="11" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox"
                 Background="#2A2A2A" Foreground="White"
                 BorderBrush="#444" BorderThickness="1"
                 Padding="6,4" FontSize="13"
                 CaretBrush="White"
                 Margin="0,0,0,12"/>

        <TextBlock Text="Start time (m:ss)" Foreground="#888"
                   FontSize="11" Margin="0,0,0,4"/>
        <TextBox x:Name="TimeBox"
                 Background="#2A2A2A" Foreground="White"
                 BorderBrush="#444" BorderThickness="1"
                 Padding="6,4" FontSize="13"
                 CaretBrush="White"
                 Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Click="Cancel_Click"
                    Background="#2A2A2A" Foreground="#888"
                    FontSize="12" FontWeight="Bold"
                    Padding="16,6" Cursor="Hand"
                    BorderThickness="0"
                    Margin="0,0,8,0"/>
            <Button Content="Save"
                    Click="Save_Click"
                    Background="#2A5A7A" Foreground="White"
                    FontSize="12" FontWeight="Bold"
                    Padding="16,6" Cursor="Hand"
                    BorderThickness="0"/>
        </StackPanel>
    </StackPanel>
</Window>
