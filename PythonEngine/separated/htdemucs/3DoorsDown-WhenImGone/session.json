    {
      "start": 0,
      "end": 19.52,
      "text": "There\u0027s another world inside of me that you may never see."
    },
    {
      "start": 19.52,
      "end": 26.400000000000002,
      "text": "There\u0027s secrets in this life that I can\u0027t hide."
    },
    {
      "start": 26.4,
      "end": 32.4,
      "text": "And where in this darkness there\u0027s a light that I can\u0027t find."
    },
    {
      "start": 32.4,
      "end": 37.4,
      "text": "Maybe it\u0027s too far away."
    },
    {
      "start": 37.4,
      "end": 40.4,
      "text": "Maybe I\u0027m just blind."
    },
    {
      "start": 43.4,
      "end": 46.4,
      "text": "Maybe I\u0027m just blind."
    },
    {
      "start": 50.4,
      "end": 52.4,
      "text": "So hold me when I\u0027m here."
    },
    {
      "start": 52.4,
      "end": 54.4,
      "text": "Drive me when I\u0027m wrong."
    },
    {
      "start": 54.4,
      "end": 55.4,
      "text": "Hold me when I\u0027m scared."
    },
    {
      "start": 55.4,
      "end": 57.4,
