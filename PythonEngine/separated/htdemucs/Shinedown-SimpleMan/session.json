    {
      "start": 0,
      "end": 16,
      "text": "Well mama told me when I was young,",
      "IsActive": false
    },
    {
      "start": 16,
      "end": 32,
      "text": "I said sit beside me, my only song, and listen closely to what I say.",
      "IsActive": false
    },
    {
      "start": 32,
      "end": 42,
      "text": "And if you do this, it\u0027ll help you some sunny day, I had a wheel.",
      "IsActive": false
    },
    {
      "start": 47,
      "end": 55,
