    {
      "start": 0,
      "end": 25,
      "text": "My eyes are open wide by the way I made it through the day",
      "IsActive": false
    },
    {
      "start": 25,
      "end": 34,
      "text": "I watched the world outside by the way I\u0027m leaving now today",
      "IsActive": false
    },
    {
      "start": 34,
      "end": 44,
      "text": "I just saw Haley\u0027s comet shoot away Said why you always running in place?",
      "IsActive": false
    },
    {
      "start": 44,
      "end": 53,
      "text": "Even the man in the moon disappeared Somewhere in the stratosphere",
      "IsActive": false
    },
    {
      "start": 53,
      "end": 62,
      "text": "Tell my mother, tell my father I\u0027ve done the best I can",
      "IsActive": false
    },
    {
      "start": 62,
      "end": 72,
      "text": "To make them realize this is my life I hope they understand",
      "IsActive": false
    },
    {
      "start": 72,
